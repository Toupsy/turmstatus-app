{
  "name": "turmstatus-app",
  "version": "1.18.0",
  "private": true,
  "description": "Turmstatus – digitales Wach- und Statussystem für Wasserrettung (Fastify + SQLite + Svelte, TypeScript-Monorepo)",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @turmstatus/web && npm run build --workspace @turmstatus/admin && npm run build --workspace @turmstatus/api",
    "dev": "npm run dev --workspace @turmstatus/api",
    "dev:web": "npm run dev --workspace @turmstatus/web",
    "dev:admin": "npm run dev --workspace @turmstatus/admin",
    "start": "node apps/api/dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty",
    "db:generate": "npm run db:generate --workspace @turmstatus/api"
  },
  "keywords": [
    "DLRG",
    "Wasserrettung",
    "Turmstatus",
    "Lagebild",
    "Rescue"
  ],
  "author": "DLRG",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "semantic-release": "^23.0.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/git": "^10.0.0"
  }
}
