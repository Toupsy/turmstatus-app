# ============================================================
# Turmstatus – Beispiel-Umgebung. Kopieren nach .env und anpassen.
# ============================================================

# --- Pflicht ---
# Signiert die Session-Cookies. MINDESTENS 32 Zeichen, zufällig.
SESSION_SECRET=bitte-aendern-mindestens-32-zeichen-zufaellig

# Erst-Admin (Hauptwache). Wird beim ersten Start angelegt, falls noch kein Admin existiert.
ADMIN_USERNAME=hauptwache
ADMIN_PASSWORD=bitte-aendern

# --- Netzwerk / Ports ---
NODE_ENV=production
HOST=0.0.0.0
PORT=3002            # öffentliche Operativ-App (darf via Cloudflare/Proxy nach außen)
ADMIN_PORT=3003      # interner Admin-Bereich
ADMIN_BIND=127.0.0.1 # Admin-Listener NUR lokal binden (nicht nach außen!)
TRUST_PROXY=1        # hinter Cloudflare/NGINX: echte Client-IP übernehmen

# --- Cookies ---
# Ohne TLS-Reverse-Proxy auf false lassen, sonst verwirft der Browser das Cookie.
COOKIE_SECURE=false

# --- Datenbank ---
DATABASE_PATH=./data/turmstatus.db

# --- Selbstregistrierung: disabled | open | code ---
REGISTRATION_MODE=disabled
# REGISTRATION_CODE=geheim   # nur bei REGISTRATION_MODE=code

# --- Optional ---
# BCRYPT_ROUNDS=10
# LOG_LEVEL=info
# APP_VERSION=1.0.0          # sonst aus dem Build/Image
