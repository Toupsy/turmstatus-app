# ============================================================
# Turmstatus – Environment-Vorlage
#
#   cp .env.example .env  und Werte eintragen.
#   .env ist gitignored, wird von docker-compose (env_file) und vom
#   lokalen `npm start` (dotenv) geladen.
# ============================================================

# ── Laufzeit ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
ADMIN_PORT=3001
# Host-Ports (docker-compose):
HTTP_PORT=3456
ADMIN_HTTP_PORT=3457

# ── Verschlüsselung & Session (PFLICHT) ─────────────────────
#   MASTER_SECRET  : openssl rand -base64 32   (min. 32 Zeichen)
#   SALT           : openssl rand -base64 16   (min. 16 Zeichen)
#   SESSION_SECRET : openssl rand -base64 32   (min. 16 Zeichen)
# ⚠ MASTER_SECRET/SALT gehen in die (optionale) Verschlüsselung ein – nicht
#   nachträglich ändern, ohne verschlüsselte Daten vorher umzuschlüsseln.
MASTER_SECRET=ERSETZE_MICH_openssl_rand_base64_32
SALT=ERSETZE_MICH_openssl_rand_base64_16
SESSION_SECRET=ERSETZE_MICH_openssl_rand_base64_32

# ── Session-Cookie HTTPS/TLS ────────────────────────────────
# COOKIE_SECURE=true → Cookie nur über HTTPS (hinter TLS-Reverse-Proxy setzen).
# Default: true bei NODE_ENV=production, sonst false.
# COOKIE_SECURE=true

# ── Erst-Admin / Hauptwache (optional) ──────────────────────
# Legt beim ersten Start ein Hauptwache-Konto an. Alternativ via /api/auth/init.
ADMIN_USERNAME=hauptwache
ADMIN_PASSWORD=ERSETZE_MICH_starkes_passwort

# ── Selbstregistrierung (optional) ───────────────────────────
# REGISTRATION_MODE: disabled (default) | open | code
# REGISTRATION_MODE=disabled
# REGISTRATION_CODE=ERSETZE_MICH_falls_code_modus

# ── Datenbank (optional) ────────────────────────────────────
# Standard: /app/data/turmstatus.db (Docker) bzw. ./data/turmstatus.db (lokal).
# DATABASE_PATH=/app/data/turmstatus.db
