# ---- Datenbank ----
POSTGRES_USER=turmstatus
POSTGRES_PASSWORD=bitte_aendern
POSTGRES_DB=turmstatus

# ---- Backend / Sicherheit ----
# WICHTIG: SECRET_KEY in Produktion durch einen langen Zufallswert ersetzen!
# z. B. erzeugen mit:  openssl rand -hex 32
SECRET_KEY=bitte_durch_langen_zufallswert_ersetzen

# Erster Administrator (Hauptwache), wird beim ersten Start angelegt
ADMIN_USERNAME=hauptwache
ADMIN_PASSWORD=bitte_aendern

# Erlaubte CORS-Origins (kommagetrennt). Hinter dem nginx-Proxy meist "*" ausreichend.
CORS_ORIGINS=*

# ---- Frontend ----
# Host-Port, unter dem die Anwendung erreichbar ist (http://NAS-IP:HTTP_PORT)
HTTP_PORT=3456
